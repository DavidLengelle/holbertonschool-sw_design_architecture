classDiagram
    class Library {
        +add_book()
        +register_user()
        +create_loan()
    }

    class Book {
        +title: str
        +author: str
        +state: bool
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +name: str
        +email: str
    }

    class Loan {
        +start_date: date
        +end_date: date
        +close_loan()
    }

    Library "1" *-- "0..*" Book
    Library "1" *-- "0..*" User
    Library "1" *-- "0..*" Loan
    Loan "0..*" --> "1" Book
    Loan "0..*" --> "1" User
